#!/usr/bin/env bash
set -euo pipefail

if ! command -v npx >/dev/null 2>&1; then
  echo "npx is required to run Playwright browser validation." >&2
  echo "Install Node.js/npm first, then rerun this script." >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required to run Playwright browser validation." >&2
  echo "Install Python 3 first, then rerun this script." >&2
  exit 1
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required to rebuild embedded UI assets before browser validation." >&2
  echo "Install pnpm first, then rerun this script." >&2
  exit 1
fi

export CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
export PWCLI="$CODEX_HOME/skills/playwright/scripts/playwright_cli.sh"

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
requested_workdir="${HARNESS_UI_WORKDIR:-}"
harness_bin="${HARNESS_UI_BINARY:-$repo_root/.local/bin/harness}"
host="${HARNESS_UI_HOST:-127.0.0.1}"
port="${HARNESS_UI_PORT:-0}"
tmp_dir="$(mktemp -d)"
server_log="$tmp_dir/harness-ui.log"
session_prefix="${HARNESS_UI_PLAYWRIGHT_SESSION:-harness-ui-smoke-$$-$(date +%s%N)-$RANDOM}"
session_nonce="$(python3 - <<'PY'
import uuid
print(uuid.uuid4().hex[:6])
PY
)"
output_dir="${HARNESS_UI_OUTPUT_DIR:-output/playwright/$session_prefix}"
playwright_root="$tmp_dir/playwright"
vite_log="$tmp_dir/vite-dev.log"
playwright_timeout_seconds="${HARNESS_UI_PLAYWRIGHT_TIMEOUT:-45}"
runtime_workdir=""

server_pid=""
lock_holder_pid=""
vite_pid=""
rail_session=""

pwcli() {
  local session="$1"
  shift
  local workdir
  workdir="$(session_workdir "$session")"
  mkdir -p "$workdir"
  python3 - "$PWCLI" "$workdir" "$playwright_timeout_seconds" "$session" "$@" <<'PY'
import subprocess
import sys

pwcli, cwd, timeout_s, session, *args = sys.argv[1:]
cmd = [pwcli, "--session", session, *args]
try:
    completed = subprocess.run(cmd, cwd=cwd, timeout=float(timeout_s), check=False)
except subprocess.TimeoutExpired:
    print(f"Playwright command timed out after {timeout_s}s: {' '.join(cmd)}", file=sys.stderr)
    sys.exit(124)
sys.exit(completed.returncode)
PY
}

pwcli_run_code_checked() {
  local session="$1"
  local code="$2"
  local output
  output="$(pwcli "$session" run-code "$code")"
  if printf '%s\n' "$output" | grep -Fq "### Error"; then
    printf '%s\n' "$output" >&2
    exit 1
  fi
  printf '%s\n' "$output"
}

pwcli_close() {
  local session="$1"
  local workdir
  workdir="$(session_workdir "$session")"
  mkdir -p "$workdir"
  python3 - "$PWCLI" "$session" "$workdir" <<'PY'
import subprocess
import sys
import os
import signal

pwcli, session, cwd = sys.argv[1:4]
proc = subprocess.Popen(
    [pwcli, "--session", session, "close"],
    cwd=cwd,
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
try:
    proc.wait(timeout=5)
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        proc.wait(timeout=2)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait()
PY
}

log_phase() {
  printf '[ui-smoke] %s\n' "$*" >&2
}

clear_pwcli_socket() {
  local session="$1"
  find "${TMPDIR:-/tmp}" -path "*/pw-*/cli/*-${session}.sock" -delete 2>/dev/null || true
}

session_workdir() {
  printf '%s/%s\n' "$playwright_root" "$1"
}

session_name() {
  printf 'hui-%s-%s\n' "$session_nonce" "$1"
}

prepare_runtime_workdir() {
  if [[ -n "$requested_workdir" ]]; then
    runtime_workdir="$requested_workdir"
    return
  fi

  runtime_workdir="$tmp_dir/runtime-workdir"
  mkdir -p "$runtime_workdir/.local"
  cp -R "$repo_root/docs" "$runtime_workdir/docs"
}


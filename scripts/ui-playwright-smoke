pwcli_run_code_checked "$timeline_inspector_session" '
async (page) => await page.evaluate(() => {
  const tabs = document.querySelector(".inspector-tabs");
  if (!tabs) {
    throw new Error("missing timeline inspector tabs");
  }
  const rect = tabs.getBoundingClientRect();
  if (rect.height < 24 || rect.width < 240) {
    throw new Error(`timeline tabs look collapsed: ${rect.width}x${rect.height}`);
  }
  return true;
})
' >/dev/null

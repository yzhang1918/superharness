#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/install-dev-harness [--install-dir <path>] [--force]

Build the current repo's harness binary into .local/bin and install a
worktree-aware `harness` wrapper from a user-local directory.

Options:
  --install-dir <path>  Override the target directory for the harness wrapper.
  --force               Replace an existing non-matching harness entry.
  -h, --help            Show this help text.
EOF
}

install_dir=""
force=0

while (($#)); do
  case "$1" in
    --install-dir)
      shift
      if (($# == 0)); then
        echo "--install-dir requires a value" >&2
        exit 2
      fi
      install_dir="$1"
      ;;
    --force)
      force=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
binary_dir="${repo_root}/.local/bin"
binary_path="${binary_dir}/harness"
repo_module_line="module github.com/catu-ai/easyharness"
legacy_repo_module_lines=(
  "module github.com/yzhang1918/microharness"
  "module github.com/yzhang1918/superharness"
)
version_package="github.com/catu-ai/easyharness/internal/version"

go_mod_matches_repo() {
  local go_mod_path="$1"
  grep -Fqx "${repo_module_line}" "${go_mod_path}" && return 0

  local legacy_line
  for legacy_line in "${legacy_repo_module_lines[@]}"; do
    grep -Fqx "${legacy_line}" "${go_mod_path}" && return 0
  done

  return 1
}

is_easyharness_root() {
  local dir="$1"
  [[ -n "${dir}" ]] || return 1
  [[ -f "${dir}/scripts/install-dev-harness" ]] || return 1
  [[ -f "${dir}/cmd/harness/main.go" ]] || return 1
  [[ -f "${dir}/go.mod" ]] || return 1
  go_mod_matches_repo "${dir}/go.mod"
}

path_has_entry() {
  local candidate="$1"
  local dir
  IFS=':' read -r -a path_entries <<< "${PATH:-}"
  for dir in "${path_entries[@]}"; do
    [[ -z "${dir}" ]] && continue
    if [[ "${dir%/}" == "${candidate%/}" ]]; then
      return 0
    fi
  done
  return 1
}

choose_install_dir() {
  if [[ -n "${install_dir}" ]]; then
    printf '%s\n' "${install_dir}"
    return
  fi

  if [[ -n "${HOME:-}" ]]; then
    printf '%s\n' "${HOME}/.local/bin"
    return
  fi

  local dir
  IFS=':' read -r -a path_entries <<< "${PATH:-}"
  for dir in "${path_entries[@]}"; do
    [[ -z "${dir}" ]] && continue
    case "${dir}" in
      */.codex/tmp/*)
        continue
        ;;
    esac
    if [[ -d "${dir}" && -w "${dir}" ]]; then
      printf '%s\n' "${dir}"
      return
    fi
  done

  printf '%s\n' "${repo_root}/.local/dev-bin"
}

target_dir="$(choose_install_dir)"
command_path="${target_dir}/harness"

if [[ "${command_path}" == "${binary_path}" ]]; then
  echo "Refusing to install the wrapper over the repo-local binary at ${binary_path}." >&2
  echo "Choose a different --install-dir." >&2
  exit 2
fi

wrapper_content() {
  cat <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

# easyharness-install-dev-wrapper
repo_module_line='module github.com/catu-ai/easyharness'
legacy_repo_module_lines=(
  'module github.com/yzhang1918/microharness'
  'module github.com/yzhang1918/superharness'
)

go_mod_matches_repo() {
  local go_mod_path="$1"
  grep -Fqx "${repo_module_line}" "${go_mod_path}" && return 0

  local legacy_line
  for legacy_line in "${legacy_repo_module_lines[@]}"; do
    grep -Fqx "${legacy_line}" "${go_mod_path}" && return 0
  done

  return 1
}

is_easyharness_root() {
  local dir="$1"
  [[ -n "${dir}" ]] || return 1
  [[ -f "${dir}/scripts/install-dev-harness" ]] || return 1
  [[ -f "${dir}/cmd/harness/main.go" ]] || return 1
  [[ -f "${dir}/go.mod" ]] || return 1
  go_mod_matches_repo "${dir}/go.mod"
}

find_repo_root() {
  local root=""
  if command -v git >/dev/null 2>&1; then
    root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if is_easyharness_root "${root}"; then
      printf '%s\n' "${root}"
      return 0
    fi
  fi

  local dir="${PWD}"
  while :; do
    if is_easyharness_root "${dir}"; then
      printf '%s\n' "${dir}"
      return 0
    fi
    if [[ "${dir}" == "/" ]]; then
      break
    fi
    dir="$(dirname "${dir}")"
  done

  return 1
}

normalize_path() {
  local path="$1"
  local dir base
  dir="$(cd "$(dirname "${path}")" 2>/dev/null && pwd -P)" || return 1
  base="$(basename "${path}")"
  printf '%s/%s\n' "${dir}" "${base}"
}

resolve_existing_path() {
  local current="$1"
  local hop_count=0

  [[ -e "${current}" || -L "${current}" ]] || return 1

  while [[ -L "${current}" ]]; do
    local dir target
    dir="$(cd "$(dirname "${current}")" 2>/dev/null && pwd -P)" || return 1
    target="$(readlink "${current}")" || return 1
    case "${target}" in
      /*)
        current="${target}"
        ;;
      *)
        current="${dir}/${target}"
        ;;
    esac
    hop_count=$((hop_count + 1))
    if (( hop_count > 40 )); then
      return 1
    fi
  done

  [[ -e "${current}" ]] || return 1
  normalize_path "${current}"
}

managed_easyharness_wrapper() {
  local path="$1"
  local inspect_path

  inspect_path="$(resolve_existing_path "${path}" 2>/dev/null || true)"
  [[ -n "${inspect_path}" && -f "${inspect_path}" ]] || return 1

  if grep -Fq '# easyharness-install-dev-wrapper' "${inspect_path}"; then
    return 0
  fi

  grep -Fq 'find_repo_root()' "${inspect_path}" &&
    grep -Fq 'cmd/harness/main.go' "${inspect_path}" &&
    return 0
}

release_harness_candidate() {
  local path="$1"
  local version_output=""

  version_output="$("${path}" --version 2>/dev/null || true)"
  [[ -n "${version_output}" ]] || return 1
  grep -Fq 'mode: release' <<< "${version_output}"
}

find_stable_harness_on_path() {
  local self_path="$1"
  local self_real_path="$2"
  local dir candidate normalized_candidate resolved_candidate
  IFS=':' read -r -a path_entries <<< "${PATH:-}"
  for dir in "${path_entries[@]}"; do
    [[ -z "${dir}" ]] && continue
    candidate="${dir%/}/harness"
    [[ -x "${candidate}" ]] || continue

    normalized_candidate="$(normalize_path "${candidate}" 2>/dev/null || true)"
    resolved_candidate="$(resolve_existing_path "${candidate}" 2>/dev/null || true)"
    if [[ -n "${self_path}" && -n "${normalized_candidate}" && "${normalized_candidate}" == "${self_path}" ]]; then
      continue
    fi
    if [[ -n "${self_real_path}" && -n "${resolved_candidate}" && "${resolved_candidate}" == "${self_real_path}" ]]; then
      continue
    fi
    if managed_easyharness_wrapper "${candidate}"; then
      continue
    fi
    if ! release_harness_candidate "${candidate}"; then
      continue
    fi

    printf '%s\n' "${candidate}"
    return 0
  done

  return 1
}

set_wrapper_paths() {
  local computed_path="" computed_real_path=""
  computed_path="$(normalize_path "${BASH_SOURCE[0]}" 2>/dev/null || true)"
  computed_real_path="$(resolve_existing_path "${BASH_SOURCE[0]}" 2>/dev/null || true)"
  wrapper_path="${computed_path}"
  wrapper_real_path="${computed_real_path}"
}

choose_out_of_tree_binary() {
  local candidate=""
  candidate="$(find_stable_harness_on_path "${wrapper_path:-}" "${wrapper_real_path:-}" 2>/dev/null || true)"
  [[ -n "${candidate}" ]] || return 1
  stable_binary_path="${candidate}"
}

wrapper_path=""
wrapper_real_path=""
stable_binary_path=""
set_wrapper_paths

binary_path=""
if repo_root="$(find_repo_root)"; then
  binary_path="${repo_root}/.local/bin/harness"
  if [[ ! -x "${binary_path}" ]]; then
    echo "No repo-local harness binary found at ${binary_path}." >&2
    echo "Run scripts/install-dev-harness from this worktree first." >&2
    exit 1
  fi
elif choose_out_of_tree_binary; then
  binary_path="${stable_binary_path}"
else
  echo "Could not find an easyharness source tree from ${PWD}, and no stable harness binary is available on PATH." >&2
  echo "Install the stable easyharness release with Homebrew so \`harness\` is on PATH, then rerun this command outside source trees." >&2
  exit 1
fi

exec "${binary_path}" "$@"
EOF
}

legacy_easyharness_link() {
  local path="$1"
  [[ -L "${path}" ]] || return 1

  local target=""
  target="$(readlink "${path}")"
  [[ -n "${target}" ]] || return 1

  if [[ "${target}" == "${binary_path}" ]]; then
    return 0
  fi

  case "${target}" in
    */.local/bin/harness)
      local candidate_root=""
      candidate_root="$(cd "$(dirname "${target}")/../.." 2>/dev/null && pwd || true)"
      if is_easyharness_root "${candidate_root}"; then
        return 0
      fi
      ;;
  esac

  return 1
}

command_contents_match() {
  local path="$1"
  [[ -f "${path}" && ! -L "${path}" ]] || return 1

  local current_contents
  current_contents="$(cat "${path}")"
  [[ "${current_contents}" == "$(wrapper_content)" ]]
}

managed_easyharness_wrapper() {
  local path="$1"
  [[ -f "${path}" && ! -L "${path}" ]] || return 1

  if grep -Fq '# easyharness-install-dev-wrapper' "${path}"; then
    return 0
  fi

  grep -Fq 'fallback_binary_path=' "${path}" &&
    grep -Fq 'find_repo_root()' "${path}" &&
    grep -Fq 'cmd/harness/main.go' "${path}" &&
    return 0

  grep -Fq 'find_repo_root()' "${path}" &&
    grep -Fq 'cmd/harness/main.go' "${path}" &&
    grep -Fq 'binary_path="${repo_root}/.local/bin/harness"' "${path}"
}

mkdir -p "${binary_dir}"
build_commit=""
if command -v git >/dev/null 2>&1; then
  build_commit="$(git -C "${repo_root}" rev-parse HEAD 2>/dev/null || true)"
fi
build_ldflags=("-X" "${version_package}.BuildMode=dev")
if [[ -n "${build_commit}" ]]; then
  build_ldflags+=("-X" "${version_package}.BuildCommit=${build_commit}")
fi
build_args=("-o" "${binary_path}" "-ldflags" "${build_ldflags[*]}" "./cmd/harness")
(
  cd "${repo_root}"
  go build "${build_args[@]}"
)
"${binary_path}" --help >/dev/null

mkdir -p "${target_dir}"
if [[ -e "${command_path}" || -L "${command_path}" ]]; then
  if [[ "${force}" -eq 1 ]]; then
    rm -f "${command_path}"
  elif legacy_easyharness_link "${command_path}"; then
    rm -f "${command_path}"
  elif command_contents_match "${command_path}"; then
    chmod 755 "${command_path}"
  elif managed_easyharness_wrapper "${command_path}"; then
    rm -f "${command_path}"
  else
    echo "Refusing to replace existing ${command_path}. Re-run with --force if you want to overwrite it." >&2
    exit 1
  fi
fi

if [[ ! -e "${command_path}" && ! -L "${command_path}" ]]; then
  wrapper_tmp="${command_path}.tmp.$$"
  wrapper_content > "${wrapper_tmp}"
  chmod 755 "${wrapper_tmp}"
  mv "${wrapper_tmp}" "${command_path}"
fi

echo "Built dev harness binary at ${binary_path}"
echo "Installed harness wrapper at ${command_path}"
echo "Verified the repo-local binary directly at ${binary_path}"

if [[ ":${PATH}:" == *":${target_dir}:"* ]]; then
  resolved_path="$(command -v harness || true)"
  if [[ -z "${resolved_path}" ]]; then
    echo "The target directory is on PATH, but \`harness\` is still not resolvable in this shell." >&2
    echo "Open a new shell and verify with: command -v harness" >&2
    exit 1
  fi
  if [[ "${resolved_path}" != "${command_path}" ]]; then
    echo "The worktree-aware wrapper was installed at ${command_path}, but \`harness\` currently resolves to ${resolved_path}." >&2
    echo "Choose an earlier install directory with --install-dir, or move ${target_dir} earlier in PATH." >&2
    exit 1
  fi
  harness --help >/dev/null
  echo "Verified harness on PATH at ${resolved_path}"
else
  echo "${target_dir} is not currently on PATH."
  echo "Add it to your shell and open a new shell, or run:"
  echo "  export PATH=\"${target_dir}:\$PATH\""
fi

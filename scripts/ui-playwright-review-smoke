)
PY

snapshot_to_file() {
  local destination="$1"
  awk '
    /^```yaml$/ { capture=1; next }
    capture && /^```$/ { capture=0; exit }
    capture { print }
  ' >"$destination"

  [[ -s "$destination" ]]
}

screenshot_path_from_output() {
  sed -n 's/^- \[Screenshot of viewport\](\(.*\))$/\1/p' | head -n 1
}

resolve_artifact_path() {
  local base_dir="$1"
  local path="$2"
  if [[ "$path" == /* ]]; then
    printf '%s\n' "$path"
    return
  fi
  printf '%s/%s\n' "$base_dir" "$path"
}

capture_screenshot() {
  local session="$1"
  local destination="$2"
  local output screenshot_path

  output="$(
    cd "$session_dir"
    "$PWCLI" --session "$session" screenshot
  )"
  screenshot_path="$(resolve_artifact_path "$session_dir" "$(printf '%s\n' "$output" | screenshot_path_from_output || true)")"
  if [[ -z "$screenshot_path" || ! -f "$screenshot_path" ]]; then
    echo "Missing Playwright screenshot for ${destination}" >&2
    printf '%s\n' "$output" >&2
    exit 1
  fi
  cp "$screenshot_path" "$destination"
}

run_code_checked() {
  local session="$1"
  local code="$2"
  local output
  output="$("$PWCLI" --session "$session" run-code "$code")"
  if printf '%s\n' "$output" | grep -Fq "### Error"; then
    printf '%s\n' "$output" >&2
    exit 1
  fi
  printf '%s\n' "$output"
}

capture_locator_screenshot() {
  local session="$1"
  local selector="$2"
  local destination="$3"
  local resolved_destination selector_js destination_js
  resolved_destination="$(resolve_artifact_path "$repo_root" "$destination")"
  selector_js="$(python3 - <<'PY' "$selector"
import json
import sys
print(json.dumps(sys.argv[1]))
PY
)"
  destination_js="$(python3 - <<'PY' "$resolved_destination"
import json
import sys
print(json.dumps(sys.argv[1]))
PY
)"
  run_code_checked "$session" "async (page) => { await page.locator(${selector_js}).first().screenshot({ path: ${destination_js} }); return true; }" >/dev/null
}

assert_visual_baseline() {
  local baseline="$1"
  local candidate="$2"
  local label="$3"
  local resolved_baseline resolved_candidate
  resolved_baseline="$(resolve_artifact_path "$repo_root" "$baseline")"
  resolved_candidate="$(resolve_artifact_path "$repo_root" "$candidate")"
  if [[ ! -f "$resolved_baseline" ]]; then
    echo "Missing review visual baseline: ${resolved_baseline}" >&2
    exit 1
  fi
  pnpm --dir "$repo_root/web" exec node "$repo_root/scripts/compare-review-visual.mjs" "$resolved_baseline" "$resolved_candidate" "$label"
}

assert_has_text() {
  local file="$1"
  local expected="$2"
  if ! grep -Fq -- "$expected" "$file"; then
    echo "Snapshot ${file} did not contain expected text: ${expected}" >&2
    cat "$file" >&2
    exit 1
  fi
}

assert_not_has_text() {
  local file="$1"
  local unexpected="$2"
  if grep -Fq -- "$unexpected" "$file"; then
    echo "Unexpected text in ${file}: ${unexpected}" >&2
    cat "$file" >&2
    exit 1
  fi
}

run_empty_review_smoke() {
  local empty_tmp_dir
  local empty_runtime_workdir
  local empty_server_log
  local empty_session_name
  local empty_session_dir
  local empty_server_pid
  local empty_base_url

  empty_tmp_dir="$(mktemp -d)"
  empty_runtime_workdir="$empty_tmp_dir/runtime-workdir"
  empty_server_log="$empty_tmp_dir/harness-ui.log"
  empty_session_name="rue-$RANDOM"
  empty_session_dir="$empty_tmp_dir/playwright"
  mkdir -p "$empty_runtime_workdir" "$empty_session_dir"

  "$harness_bin" plan template -title "Review UI Empty" -output "$empty_runtime_workdir/docs/plans/active/2026-04-02-review-ui-empty.md" >/dev/null
  mkdir -p "$empty_runtime_workdir/.local/harness"
  printf '%s' '{"plan_path":"docs/plans/active/2026-04-02-review-ui-empty.md"}' >"$empty_runtime_workdir/.local/harness/current-plan.json"

  (
    cd "$empty_runtime_workdir"
    "$harness_bin" ui --no-open --host "$host" --port "$port" >"$empty_server_log" 2>&1
  ) &
  empty_server_pid="$!"

  empty_base_url=""
  for _ in $(seq 1 150); do
    empty_base_url="$(sed -n 's/^Harness UI listening at \(http:\/\/[^[:space:]]*\)$/\1/p' "$empty_server_log" | tail -n 1)"
    if [[ -n "$empty_base_url" ]] && curl -sf "${empty_base_url}/review" >/dev/null; then
      break
    fi
    sleep 0.2
  done

  if [[ -z "$empty_base_url" ]]; then
    echo "Harness UI failed to start for empty review smoke." >&2
    cat "$empty_server_log" >&2 || true
    kill "$empty_server_pid" >/dev/null 2>&1 || true
    wait "$empty_server_pid" >/dev/null 2>&1 || true
    rm -rf "$empty_tmp_dir"
    exit 1
  fi

  log_phase "opening empty active-plan /review"
  clear_pwcli_socket "$empty_session_name"
  "$PWCLI" --session "$empty_session_name" open "${empty_base_url}/review" >/dev/null
  "$PWCLI" --session "$empty_session_name" snapshot | snapshot_to_file "$empty_tmp_dir/review-empty.yml"
  assert_has_text "$empty_tmp_dir/review-empty.yml" "No review rounds recorded yet for the current plan."
  assert_not_has_text "$empty_tmp_dir/review-empty.yml" "WIP"

  python3 - "$PWCLI" "$empty_session_name" "$empty_session_dir" <<'PY'
import os
import signal
import subprocess
import sys

pwcli, session, cwd = sys.argv[1:4]
proc = subprocess.Popen(
    [pwcli, "--session", session, "close"],
    cwd=cwd,
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
try:
    proc.wait(timeout=5)
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        proc.wait(timeout=2)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait()
PY

  kill "$empty_server_pid" >/dev/null 2>&1 || true
  wait "$empty_server_pid" >/dev/null 2>&1 || true
  rm -rf "$empty_tmp_dir"
}

run_empty_review_smoke

session_name="rum-$RANDOM"
session_dir="$tmp_dir/playwright-main"
mkdir -p "$session_dir"
clear_pwcli_socket "$session_name"

"$harness_bin" plan template -title "Review UI Smoke Fixture" -output "$runtime_workdir/docs/plans/active/2026-04-02-review-ui-smoke.md" >/dev/null

button_ref_from_snapshot() {
  local label="$1"
  local snapshot="$2"
  local ref
  ref="$(
    grep -F "\"$label\"" "$snapshot" | head -n 1 | sed -n 's/.*\[ref=\(e[0-9][0-9]*\)\].*/\1/p' || true
  )"
  if [[ -n "$ref" ]]; then
    printf '%s\n' "$ref"
    return 0
  fi
  ref="$(
    grep -F "$label" "$snapshot" | grep '\[ref=e' | head -n 1 | sed -n 's/.*\[ref=\(e[0-9][0-9]*\)\].*/\1/p' || true
  )"
  printf '%s\n' "$ref"
  return 0
}

tab_ref_from_snapshot() {
  local label="$1"
  local snapshot="$2"
  local ref
  ref="$(
    grep -F "\"$label\"" "$snapshot" | head -n 1 | sed -n 's/.*\[ref=\(e[0-9][0-9]*\)\].*/\1/p' || true
  )"
  if [[ -n "$ref" ]]; then
    printf '%s\n' "$ref"
    return 0
  fi
  ref="$(
    grep -F "$label" "$snapshot" | grep '\[ref=e' | head -n 1 | sed -n 's/.*\[ref=\(e[0-9][0-9]*\)\].*/\1/p' || true
  )"
  printf '%s\n' "$ref"
  return 0
}


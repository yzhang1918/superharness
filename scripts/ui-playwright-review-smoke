run_code_checked "$session_name" '
async (page) => await page.evaluate(() => {
  const rows = [...document.querySelectorAll(".explorer-item")];
  if (rows.length < 2) {
    throw new Error("expected multiple review rounds for explorer validation");
  }
  const activeRow = rows.find((candidate) => candidate.classList.contains("is-active"));
  if (!activeRow) {
    throw new Error("missing active review round row");
  }
  if (activeRow.getAttribute("aria-pressed") !== "true") {
    throw new Error("active review round is not marked pressed");
  }
  const activeMeta = activeRow.querySelector(".review-round-status-text");
  if (!activeMeta || !/(PASS|CHG|WAIT|AGGR|DEG|WIP|DONE|PART)/.test(activeMeta.textContent || "")) {
    throw new Error(`active row is missing visible status token: ${(activeMeta && activeMeta.textContent) || ""}`);
  }
  const initialSelected = document.querySelector(".inspector-tabs [aria-selected=\"true\"]");
  if (!initialSelected || (initialSelected.textContent || "").trim() !== "Summary") {
    throw new Error(`expected Summary to be selected on first load, got ${(initialSelected && initialSelected.textContent) || ""}`);
  }
  const row = rows.find((candidate) => !candidate.classList.contains("is-active")) ?? rows[0];
  const rowStyle = getComputedStyle(row);
  if (!rowStyle.boxShadow || rowStyle.boxShadow === "none") {
    throw new Error("missing explorer status rail");
  }
  const statusText = row.getAttribute("aria-label") || "";
  if (!/Pass|Changes requested|Waiting|Degraded|Complete|Aggregated|Incomplete|In progress/.test(statusText)) {
    throw new Error(`missing readable status text in row label: ${statusText}`);
  }
  const indicator = row.querySelector(".review-round-indicator");
  if (!indicator) {
    throw new Error("missing explorer status indicator");
  }
  const rect = indicator.getBoundingClientRect();
  if (rect.width < 6 || rect.height < 6) {
    throw new Error(`status indicator too small: ${rect.width}x${rect.height}`);
  }
  return true;
})
' >/dev/null
run_code_checked "$session_name" '
async (page) => {
  const frame = page.locator(".workbench-page");
  const divider = page.getByRole("separator", { name: /Review width/i });
  const before = await frame.evaluate((node) => getComputedStyle(node).gridTemplateColumns);
  const box = await divider.boundingBox();
  if (!box) {
    throw new Error("missing review splitter");
  }
  await page.mouse.move(box.x + box.width / 2, box.y + box.height / 2);
  await page.mouse.down();
  await page.mouse.move(box.x + box.width / 2 + 64, box.y + box.height / 2, { steps: 6 });
  await page.mouse.up();
  await divider.focus();
  await page.keyboard.press("ArrowLeft");
  const after = await frame.evaluate((node) => getComputedStyle(node).gridTemplateColumns);
  const stored = await page.evaluate(() => window.localStorage.getItem("harness-ui:explorer-width:review"));
  if (before === after) {
    throw new Error(`review splitter width did not change: ${before}`);
  }
  if (!stored) {
    throw new Error("review splitter width was not persisted");
  }
  return { before, after, stored };
}
' >/dev/null


    encoding="utf-8",
)
sub_nine.write_text(
    json.dumps(
        {
            "round_id": "review-009-delta",
            "slot": "risk",
            "dimension": "Risk",
            "submitted_at": "2026-04-02T13:21:30Z",
            "findings": [],
        }
    ),
    encoding="utf-8",
)
PY


assert_has_text "${output_dir}/review-damaged-round.yml" "Ledger is not valid JSON."
assert_has_text "${output_dir}/review-damaged-round.yml" "malformed"
assert_not_has_text "${output_dir}/review-damaged-round.yml" "Aggregate review passed cleanly."

damaged_artifacts_ref="$(button_ref_from_snapshot "Artifacts" "${output_dir}/review-damaged-round.yml")"
if [[ -z "$damaged_artifacts_ref" ]]; then
  echo "Could not find damaged-round Artifacts button." >&2
  cat "${output_dir}/review-damaged-round.yml" >&2
  exit 1
fi
"$PWCLI" --session "$session_name" click "$damaged_artifacts_ref" >/dev/null
"$PWCLI" --session "$session_name" snapshot | snapshot_to_file "${output_dir}/review-damaged-artifacts.yml"
assert_has_text "${output_dir}/review-damaged-artifacts.yml" "Round artifacts and supporting metadata"
assert_has_text "${output_dir}/review-damaged-artifacts.yml" "Ledger"
damaged_ledger_ref="$(tab_ref_from_snapshot "Ledger" "${output_dir}/review-damaged-artifacts.yml")"
if [[ -z "$damaged_ledger_ref" ]]; then
  echo "Could not find damaged-round Ledger artifact tab." >&2
  cat "${output_dir}/review-damaged-artifacts.yml" >&2
  exit 1
fi
"$PWCLI" --session "$session_name" click "$damaged_ledger_ref" >/dev/null
"$PWCLI" --session "$session_name" snapshot | snapshot_to_file "${output_dir}/review-damaged-ledger-artifact.yml"
assert_has_text "${output_dir}/review-damaged-ledger-artifact.yml" "Invalid"
assert_has_text "${output_dir}/review-damaged-ledger-artifact.yml" "Ledger is not valid JSON."
damaged_artifacts_close_ref="$(button_ref_from_snapshot "Close" "${output_dir}/review-damaged-ledger-artifact.yml")"
if [[ -z "$damaged_artifacts_close_ref" ]]; then
  echo "Could not find damaged-round Artifacts close button." >&2
  cat "${output_dir}/review-damaged-ledger-artifact.yml" >&2
  exit 1
fi
"$PWCLI" --session "$session_name" click "$damaged_artifacts_close_ref" >/dev/null

risk_ref="$(tab_ref_from_snapshot "Risk" "${output_dir}/review-damaged-round.yml")"
if [[ -z "$risk_ref" ]]; then
  echo "Could not find damaged-round Risk reviewer tab." >&2
  cat "${output_dir}/review-damaged-round.yml" >&2
  exit 1
fi
"$PWCLI" --session "$session_name" click "$risk_ref" >/dev/null
"$PWCLI" --session "$session_name" snapshot | snapshot_to_file "${output_dir}/review-damaged-risk.yml"
assert_has_text "${output_dir}/review-damaged-risk.yml" "Risk"
assert_has_text "${output_dir}/review-damaged-risk.yml" "Assigned task"
assert_has_text "${output_dir}/review-damaged-risk.yml" "Returned result"
assert_has_text "${output_dir}/review-damaged-risk.yml" "Check for hidden workflow or data risks."
assert_has_text "${output_dir}/review-damaged-risk.yml" "Recovered while the ledger is malformed."
assert_has_text "${output_dir}/review-damaged-risk.yml" "No findings recorded for this reviewer."

manifest_ref="$(button_ref_from_snapshot "review-006-delta Degraded Delta Apr 2, 2026, 8:42 PM 1/1 submitted" "${output_dir}/review-damaged-round.yml")"
if [[ -z "$manifest_ref" ]]; then
  manifest_ref="$(button_ref_from_snapshot "review-006-delta" "${output_dir}/review-damaged-round.yml")"
fi
if [[ -z "$manifest_ref" ]]; then
  echo "Could not find manifest-damaged round." >&2
  cat "${output_dir}/review-damaged-round.yml" >&2
  exit 1
fi
"$PWCLI" --session "$session_name" click "$manifest_ref" >/dev/null
"$PWCLI" --session "$session_name" snapshot | snapshot_to_file "${output_dir}/review-manifest-damaged.yml"
assert_has_text "${output_dir}/review-manifest-damaged.yml" "Degraded"
assert_has_text "${output_dir}/review-manifest-damaged.yml" "Manifest is not valid JSON."

aggregate_ref="$(button_ref_from_snapshot "Step 4 closeout Degraded Delta · step 4 · rev 2 Apr 2, 2026, 8:50 PM 1/1 submitted" "${output_dir}/review-manifest-damaged.yml")"
if [[ -z "$aggregate_ref" ]]; then
  aggregate_ref="$(button_ref_from_snapshot "Step 4 closeout" "${output_dir}/review-manifest-damaged.yml")"
fi
if [[ -z "$aggregate_ref" ]]; then
  echo "Could not find aggregate-damaged round." >&2
  cat "${output_dir}/review-manifest-damaged.yml" >&2
  exit 1
fi
"$PWCLI" --session "$session_name" click "$aggregate_ref" >/dev/null
"$PWCLI" --session "$session_name" snapshot | snapshot_to_file "${output_dir}/review-aggregate-damaged.yml"
assert_has_text "${output_dir}/review-aggregate-damaged.yml" "Degraded"
assert_has_text "${output_dir}/review-aggregate-damaged.yml" "Aggregate is not valid JSON."

rm -rf "$fixture_reviews_dir"
printf 'not-a-directory\n' > "$fixture_reviews_dir"
"$PWCLI" --session "$session_name" run-code "async (page) => { await page.goto('${base_url}/review?failure=1'); }" >/dev/null
"$PWCLI" --session "$session_name" snapshot | snapshot_to_file "${output_dir}/review-error.yml"
assert_has_text "${output_dir}/review-error.yml" "Unable to enumerate review rounds for the current plan."
assert_has_text "${output_dir}/review-error.yml" "reviews:"
assert_has_text "${output_dir}/review-error.yml" "not a directory"

log_phase "review UI smoke validation passed"
echo "Playwright review UI smoke validation passed for ${base_url}"
log_phase "review smoke snapshots written to ${output_dir}"

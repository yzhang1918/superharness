run_code_checked "$session_name" '
async (page) => await page.evaluate(() => {
  const sectionTitles = [...document.querySelectorAll(".review-tab-panel .section-head h2")].map((node) => node.textContent?.trim() || "");
  const assignedIndex = sectionTitles.indexOf("Assigned task");
  const resultIndex = sectionTitles.indexOf("Returned result");
  const processIndex = sectionTitles.indexOf("Review process");
  if (assignedIndex === -1 || resultIndex === -1 || processIndex === -1) {
    throw new Error(`missing reviewer section headings: ${sectionTitles.join(" | ")}`);
  }
  if (!(assignedIndex < resultIndex && resultIndex < processIndex)) {
    throw new Error(`unexpected reviewer section order: ${sectionTitles.join(" | ")}`);
  }
  const rawButton = [...document.querySelectorAll(".subtle-button")].find((node) => node.textContent?.includes("Raw JSON"));
  const processHeading = [...document.querySelectorAll(".review-tab-panel .section-head h2")].find((node) => node.textContent?.trim() === "Review process");
  if (!rawButton || !processHeading) {
    throw new Error("missing raw JSON button or review process heading");
  }
  const rawRect = rawButton.getBoundingClientRect();
  const processRect = processHeading.getBoundingClientRect();
  if (rawRect.top >= processRect.top) {
    throw new Error(`raw JSON control was not promoted above the process section: ${rawRect.top} vs ${processRect.top}`);
  }
  return true;
})
' >/dev/null

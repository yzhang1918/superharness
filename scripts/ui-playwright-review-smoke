#!/usr/bin/env bash
set -euo pipefail

if ! command -v npx >/dev/null 2>&1; then
  echo "npx is required to run Playwright browser validation." >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required to run Playwright browser validation." >&2
  exit 1
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required to rebuild embedded UI assets before browser validation." >&2
  exit 1
fi

export CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
export PWCLI="$CODEX_HOME/skills/playwright/scripts/playwright_cli.sh"
export PATH="$HOME/.local/bin:$PATH"

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
harness_bin="${HARNESS_UI_BINARY:-$repo_root/.local/bin/harness}"
host="${HARNESS_UI_HOST:-127.0.0.1}"
port="${HARNESS_UI_PORT:-0}"
tmp_dir="$(mktemp -d)"
runtime_workdir="$tmp_dir/runtime-workdir"
server_log="$tmp_dir/harness-ui.log"
session_name="ruis-$$-$RANDOM"
session_dir="$tmp_dir/playwright"
output_dir="${HARNESS_UI_OUTPUT_DIR:-output/playwright/$session_name}"
server_pid=""

log_phase() {
  printf '[review-ui-smoke] %s\n' "$*" >&2
}

clear_pwcli_socket() {
  local session="$1"
  find "${TMPDIR:-/tmp}" -path "*/pw-*/cli/*-${session}.sock" -delete 2>/dev/null || true
}

pwcli_close() {
  python3 - "$PWCLI" "$session_name" "$session_dir" <<'PY'
import subprocess
import sys
import os
import signal

pwcli, session, cwd = sys.argv[1:4]
proc = subprocess.Popen(
    [pwcli, "--session", session, "close"],
    cwd=cwd,
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
try:
    proc.wait(timeout=5)
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        proc.wait(timeout=2)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait()
PY
}

stop_pid() {
  local pid="$1"
  if [[ -z "$pid" ]]; then
    return
  fi
  kill "$pid" >/dev/null 2>&1 || true
  for _ in $(seq 1 20); do
    if ! kill -0 "$pid" >/dev/null 2>&1; then
      wait "$pid" >/dev/null 2>&1 || true
      return
    fi
    sleep 0.1
  done
  kill -9 "$pid" >/dev/null 2>&1 || true
  wait "$pid" >/dev/null 2>&1 || true
}

cleanup() {
  if [[ -n "$server_pid" ]]; then
    stop_pid "$server_pid"
  fi
  pwcli_close >/dev/null 2>&1 || true
  rm -rf "$tmp_dir"
}

trap cleanup EXIT

if [[ ! -x "$harness_bin" ]]; then
  echo "Expected repo-local harness binary at ${harness_bin}" >&2
  echo "Run scripts/install-dev-harness first, or override HARNESS_UI_BINARY." >&2
  exit 1
fi

mkdir -p "$runtime_workdir" "$session_dir" "$output_dir"

log_phase "rebuilding embedded UI assets"
pnpm --dir "$repo_root/web" build >/dev/null
log_phase "refreshing local harness binary"
"$repo_root/scripts/install-dev-harness" >/dev/null
harness_bin="${HARNESS_UI_BINARY:-$repo_root/.local/bin/harness}"

log_phase "seeding active-plan review fixture"
python3 - <<'PY' "$runtime_workdir"
import json
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
plan_rel = "docs/plans/active/2026-04-02-review-ui-smoke.md"
plan_path = root / plan_rel
plan_path.parent.mkdir(parents=True, exist_ok=True)

plan_stem = "2026-04-02-review-ui-smoke"
